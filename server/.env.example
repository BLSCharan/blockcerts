MONGO_URI=your_mongodb_uri
PINATA_API_KEY=your_pinata_key
PINATA_SECRET_API_KEY=your_pinata_secret
RPC_URL=your_alchemy_rpc
PRIVATE_KEY=your_wallet_private_key
CONTRACT_ADDRESS=your_contract_address

# JWT Configuration (NEW - for authentication system)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_this_in_production
JWT_EXPIRE=7d

# Server Port
PORT=5000
NODE_ENV=development

# Email Configuration (for password reset feature)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@blockcert.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173